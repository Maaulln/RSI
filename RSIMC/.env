# Application
DEBUG=False
ENV=development
APP_NAME=DARSI-CS

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
DATABASE_URL=postgresql://darsi_user:darsi_password@localhost:5432/darsi_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Services
OLLAMA_URL=http://localhost:11434
WHISPER_URL=http://localhost:8001
TTS_URL=http://localhost:8002
OCR_URL=http://localhost:8003
FACE_RECOGNITION_URL=http://localhost:8004

# LLM
LLM_MODEL=mistral
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7

# External APIs
MY_ERSIY_API_URL=https://api.my-ersiy.com
MY_ERSIY_API_KEY=your-api-key

BPJS_API_URL=https://api.bpjs.com
BPJS_API_KEY=your-api-key

SIM_RS_API_URL=http://localhost:9000
SIM_RS_API_KEY=your-api-key

# File Upload
UPLOAD_DIR=/tmp/darsi_uploads
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NODE_ID=NODE-01
